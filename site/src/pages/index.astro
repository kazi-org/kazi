---
import Layout from "../layouts/Layout.astro";
import {
  INSTALL_CMD,
  POSITIONING,
  KUBERNETES_LINE,
  HARNESSES,
} from "../canonical.mjs";

const REPO = "https://github.com/kazi-org/kazi";

// Version is injected at build time from the repo-root release-please manifest
// (see astro.config.mjs `define`), so it can never drift from the actual release.
const VERSION = __KAZI_VERSION__;

// Render the canonical HARNESSES list as readable prose: "a, b and c".
const harnessList =
  HARNESSES.length <= 1
    ? HARNESSES.join("")
    : `${HARNESSES.slice(0, -1).join(", ")} and ${HARNESSES[HARNESSES.length - 1]}`;

const features = [
  {
    title: "Objective termination",
    body: "kazi cannot declare success while any predicate is failing. “Done” means tests pass, the endpoint answers, the change is deployed — not an agent's say-so.",
  },
  {
    title: "Drives any coding agent",
    body: `It conducts a harness; it is not one. Today it drives ${harnessList}; add any other CLI agent by declaring a profile — no core change.`,
  },
  {
    title: "Bring Your Own Model",
    body: "Use cloud models or run entirely locally. Wire kazi to a local model (e.g., Llama 3, Qwen) via opencode for zero data leaks. Your context stays on your hardware.",
  },
  {
    title: "AI-Ready Execution",
    body: "kazi creates deterministic goals that coding agents can naturally pursue. It understands your codebase and drives agents safely within their allowed blast radius.",
  },
  {
    title: "Stops honestly",
    body: "If it can't converge, it tells you why — stuck on the same failure, or out of budget — instead of pretending it finished.",
  },
  {
    title: "One self-contained binary",
    body: "brew install and go. The binary bundles the runtime and a SQLite read-model, so every iteration and decision is persisted — no Erlang prerequisite.",
  },
];

const loop = [
  ["Observe", "evaluate every predicate against reality"],
  ["Diff", "compare desired vs actual state"],
  ["Dispatch", "hand the failing slice to a coding agent"],
  ["Re-observe", "re-check the predicates"],
  ["Decide", "converged, stuck, or over budget"],
];

const comparison = [
  [
    "“The agent says it’s done.” You trust it on faith.",
    "Every predicate verified true, with stored evidence. Truth lives in the controller, not the agent.",
  ],
  [
    "Two parallel agents edit the same files → merge conflicts.",
    "Agents lease their blast radius first — disjoint work runs free, overlapping work serializes.",
  ],
  [
    "Green tests on a laptop, broken in production.",
    "A live predicate probes the deployed endpoint. Green-on-my-machine is never enough.",
  ],
  [
    "It stops when it feels finished.",
    "It stops only on converged, stuck, or over-budget — and tells you which.",
  ],
];

const personas = [
  [
    "Builders who ship fast but need reliability",
    "If an agent has ever “finished” something that wasn’t actually done, objective termination is the guardrail against plausible-but-broken output.",
  ],
  [
    "Teams running parallel coding agents",
    "Resource leases coordinate who edits what before any file changes, so concurrent runs converge instead of collide.",
  ],
  [
    "Engineers who refuse “works on my machine”",
    "Predicates can verify the live, deployed system — not just the local checkout.",
  ],
];
---

<Layout>
  <!-- Nav -->
  <header class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
    <a href="/" class="flex items-center gap-2" aria-label="kazi home">
      <img src="/logo/kazi-mark.svg" alt="" width="34" height="34" />
      <span class="ui-strong text-xl font-bold tracking-tight">kazi</span>
    </a>
    <nav class="flex items-center gap-6 text-sm" aria-label="Primary">
      <a href="#how" class="ui-body ui-link">How it works</a>
      <a href="#install" class="ui-body ui-link">Install</a>
      <a
        href={REPO}
        class="ui-outline rounded-lg border px-3 py-1.5 font-medium"
        >GitHub</a
      >
    </nav>
  </header>

  <!-- Hero -->
  <main>
    <section class="relative overflow-hidden" aria-labelledby="hero-heading">
      <div
        class="kazi-gradient pointer-events-none absolute -top-40 left-1/2 h-96 w-[42rem] -translate-x-1/2 rounded-full opacity-20 blur-[120px]"
        aria-hidden="true"
      >
      </div>
      <div class="mx-auto max-w-4xl px-6 pb-16 pt-16 text-center sm:pt-24">
        <a
          href={REPO}
          class="ui-chip inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs"
        >
          <span class="kazi-text font-semibold">Open source</span>
          <span class="ui-muted">Apache-2.0 &middot; v<span id="kazi-version">{VERSION}</span></span>
        </a>
        <h1
          id="hero-heading"
          class="ui-strong mt-6 text-balance text-4xl font-extrabold tracking-tight sm:text-6xl"
        >
          Describe what <span class="kazi-text">&ldquo;done&rdquo;</span> looks like.<br />
          kazi makes it true &mdash; and proves it.
        </h1>
        <p class="ui-body mx-auto mt-6 max-w-2xl text-pretty text-lg">
          <em>kazi</em> is <strong class="ui-strong">{POSITIONING}</strong>. Tell it the
          outcome you want &mdash; in plain English or a short goal-file &mdash; and it
          drives a coding agent in a loop until that outcome is <em>objectively</em> real:
          tests pass, the endpoint is live, the change is deployed.
        </p>

        <!-- Install CTA -->
        <div class="mx-auto mt-8 flex max-w-xl flex-col items-center gap-3">
          <button
            id="copy-install"
            type="button"
            class="ui-code group flex w-full items-center justify-between gap-4 rounded-xl border px-5 py-4 text-left font-mono text-sm"
            data-cmd={INSTALL_CMD}
            title="Copy the install command"
          >
            <span><span class="ui-muted">$ </span>{INSTALL_CMD}</span>
            <span
              class="ui-chip ui-muted shrink-0 rounded-md border px-2 py-1 text-xs"
              id="copy-label">copy</span
            >
          </button>
          <div class="flex flex-wrap items-center justify-center gap-3">
            <a
              href="#install"
              class="kazi-gradient rounded-xl px-5 py-3 font-semibold text-[#06101f] shadow-lg shadow-blue-500/20 hover:opacity-95"
              >Get started</a
            >
            <a
              href={REPO}
              class="ui-outline rounded-xl border px-5 py-3 font-semibold"
              >Star on GitHub</a
            >
          </div>
        </div>

        <p class="ui-muted mt-8 text-sm">
          Think of it like <strong class="ui-body">{KUBERNETES_LINE}</strong>: you
          declare desired state, kazi watches actual state, and it closes the gap until the
          two match.
        </p>

        <!-- Proof artifact: the loop converging on a real goal -->
        <figure class="mx-auto mt-12 max-w-3xl">
          <img
            src="/proof-loop.svg"
            alt="kazi reconcile loop converging: across four iterations the failing predicate set shrinks from [tests, livez] to empty, then go test passes and the deployed GET /livez returns 200 ok — converged."
            class="ui-hairline w-full rounded-xl border shadow-2xl shadow-black/40"
            width="820"
            height="372"
            loading="lazy"
          />
          <figcaption class="ui-muted mt-3 text-xs">
            A real goal &mdash; <em>tests pass and the deployed <code>/livez</code> returns
            ok</em> &mdash; driven to convergence. Done is observed, not asserted.
          </figcaption>
        </figure>
      </div>
    </section>

    <!-- Features -->
    <section class="mx-auto max-w-6xl px-6 py-12" aria-labelledby="features-heading">
      <h2 id="features-heading" class="sr-only">Why kazi</h2>
      <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
        {
          features.map((f) => (
            <div class="ui-card rounded-2xl border p-6">
              <h3 class="ui-strong text-lg font-semibold">{f.title}</h3>
              <p class="ui-body mt-2 text-sm leading-relaxed">{f.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- 60-second mental model -->
    <section id="how" class="mx-auto max-w-6xl px-6 py-12" aria-labelledby="how-heading">
      <h2 id="how-heading" class="ui-strong text-center text-3xl font-bold tracking-tight">
        The 60-second mental model
      </h2>
      <p class="ui-body mx-auto mt-3 max-w-2xl text-center">
        A reconciliation loop for software goals. It runs until the predicates are
        objectively true, stuck, or over budget.
      </p>
      <ol class="mx-auto mt-10 grid max-w-4xl gap-3 sm:grid-cols-5">
        {
          loop.map(([step, desc], i) => (
            <li class="ui-card rounded-xl border p-4 text-center">
              <div class="kazi-text text-2xl font-extrabold">{i + 1}</div>
              <div class="ui-strong mt-1 font-semibold">{step}</div>
              <div class="ui-muted mt-1 text-xs">{desc}</div>
            </li>
          ))
        }
      </ol>
    </section>

    <!-- With vs. without kazi -->
    <section class="mx-auto max-w-5xl px-6 py-12" aria-labelledby="compare-heading">
      <h2 id="compare-heading" class="ui-strong text-center text-3xl font-bold tracking-tight">
        With kazi vs. without
      </h2>
      <div class="ui-hairline mt-10 overflow-hidden rounded-2xl border">
        <div class="ui-card grid grid-cols-2 text-sm font-semibold">
          <div class="ui-hairline ui-muted border-b px-5 py-3">Without kazi</div>
          <div class="ui-hairline ui-strong border-b border-l px-5 py-3">With kazi</div>
        </div>
        {
          comparison.map(([before, after], i) => (
            <div class="grid grid-cols-2 text-sm">
              <div
                class:list={[
                  "ui-body px-5 py-4",
                  i < comparison.length - 1 && "ui-hairline border-b",
                ]}
              >
                {before}
              </div>
              <div
                class:list={[
                  "ui-body ui-hairline border-l px-5 py-4",
                  i < comparison.length - 1 && "border-b",
                ]}
              >
                {after}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Who it's for -->
    <section class="mx-auto max-w-6xl px-6 py-12" aria-labelledby="who-heading">
      <h2 id="who-heading" class="ui-strong text-center text-3xl font-bold tracking-tight">Who it's for</h2>
      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        {
          personas.map(([who, why]) => (
            <div class="ui-card rounded-2xl border p-6">
              <h3 class="ui-strong text-base font-semibold">{who}</h3>
              <p class="ui-body mt-2 text-sm leading-relaxed">{why}</p>
            </div>
          ))
        }
      </div>
      <p class="ui-muted mx-auto mt-8 max-w-2xl text-center text-sm">
        <strong class="ui-body">Not for you (yet)</strong> if you want an agent to
        decide <em>what</em> to build &mdash; that's your call; kazi only drives toward an
        outcome you declare. It also needs a coding harness
        (<code class="ui-body">claude</code>,
        <code class="ui-body">opencode</code>, &hellip;) on your PATH &mdash; kazi
        drives one, it isn't one.
      </p>
    </section>

    <!-- Install + first goal -->
    <section id="install" class="mx-auto max-w-4xl px-6 py-12" aria-labelledby="install-heading">
      <h2 id="install-heading" class="ui-strong text-3xl font-bold tracking-tight">Install and run a goal</h2>
      <div class="mt-6 space-y-6">
        <div>
          <p class="ui-body text-sm font-semibold">1. Install</p>
          <pre class="ui-code mt-2 overflow-x-auto rounded-xl border p-4 font-mono text-sm"><code>{INSTALL_CMD}</code></pre>
          <p class="ui-muted mt-2 text-xs">
            A coding agent (<code class="ui-body">claude</code> or
            <code class="ui-body">opencode</code>) must be on your PATH &mdash; kazi
            drives one, it does not bundle one.
          </p>
        </div>
        <div>
          <p class="ui-body text-sm font-semibold">2. Describe what you want</p>
          <pre class="ui-code mt-2 overflow-x-auto rounded-xl border p-4 font-mono text-sm"><code>kazi propose "a /healthz endpoint that returns 200"
kazi approve &lt;proposal-ref&gt;</code></pre>
        </div>
        <div>
          <p class="ui-body text-sm font-semibold">3. Drive it to convergence</p>
          <pre class="ui-code mt-2 overflow-x-auto rounded-xl border p-4 font-mono text-sm"><code>kazi run my-goal.toml --workspace ./my-project</code></pre>
          <p class="ui-muted mt-2 text-xs">
            kazi loops &mdash; observe, dispatch, re-observe &mdash; and exits 0 only when
            every predicate is objectively true.
          </p>
        </div>
      </div>
      <div class="mt-8">
        <a href={`${REPO}#readme`} class="kazi-text font-semibold hover:underline"
          >Read the full docs and quickstarts on GitHub &rarr;</a
        >
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="ui-hairline border-t">
    <div
      class="ui-muted mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 py-8 text-sm sm:flex-row"
    >
      <div class="flex items-center gap-2">
        <img src="/logo/kazi-mark.svg" alt="" width="22" height="22" />
        <span>kazi &middot; Apache-2.0 &middot; &copy; Sire Run, Inc.</span>
      </div>
      <nav class="flex items-center gap-5" aria-label="Footer">
        <a href={REPO} class="ui-link">GitHub</a>
        <a href={`${REPO}/releases`} class="ui-link">Releases</a>
        <a href={`${REPO}/blob/main/docs/concept.md`} class="ui-link">Concept</a>
      </nav>
    </div>
  </footer>

  <script>
    const btn = document.getElementById("copy-install");
    const label = document.getElementById("copy-label");
    btn?.addEventListener("click", async () => {
      const cmd = btn.getAttribute("data-cmd") ?? "";
      try {
        await navigator.clipboard.writeText(cmd);
        if (label) {
          label.textContent = "copied!";
          setTimeout(() => (label.textContent = "copy"), 1500);
        }
      } catch {
        /* clipboard unavailable; no-op */
      }
    });

    // Dynamic version: the build-time value (from .release-please-manifest.json) is
    // the fallback; on load we fetch the latest GitHub release so the badge is never
    // stale between deploys -- no site rebuild needed on a version bump. Cached in
    // localStorage (1h TTL) to stay well under the unauthenticated API rate limit;
    // any failure silently keeps the baked-in fallback.
    (async () => {
      const el = document.getElementById("kazi-version");
      if (!el) return;
      const KEY = "kazi-latest-version";
      const TTL = 3600000;
      try {
        const c = JSON.parse(localStorage.getItem(KEY) || "null");
        if (c && c.v && Date.now() - c.t < TTL) {
          el.textContent = c.v;
          return;
        }
      } catch {
        /* ignore cache read errors */
      }
      try {
        const r = await fetch(
          "https://api.github.com/repos/kazi-org/kazi/releases/latest",
        );
        if (!r.ok) return;
        const data = await r.json();
        const v = (data.tag_name ?? "").replace(/^v/, "");
        if (!v) return;
        el.textContent = v;
        try {
          localStorage.setItem(KEY, JSON.stringify({ v, t: Date.now() }));
        } catch {
          /* ignore cache write errors */
        }
      } catch {
        /* offline / rate-limited: keep the build-time fallback */
      }
    })();
  </script>
</Layout>
