---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "kazi — the missing outer loop for coding agents",
  description = "Describe what “done” looks like. kazi drives a coding agent in a loop until the outcome is objectively real — tests pass, the endpoint is live, the change is deployed — or it stops and tells you why.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL("/logo/kazi-badge.svg", Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/logo/kazi-badge.svg" />
    <meta name="theme-color" content="#0b1220" />

    <!-- OpenGraph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="min-h-screen bg-[#0b1220] text-slate-200 antialiased selection:bg-violet-500/30">
    <slot />
  </body>
</html>
