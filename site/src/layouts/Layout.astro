---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "kazi — the missing outer loop for coding agents",
  description = "Describe what “done” looks like. kazi drives a coding agent in a loop until the outcome is objectively real — tests pass, the endpoint is live, the change is deployed — or it stops and tells you why.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
// A real raster OG image (1200x630 PNG). SVG OG images are not rendered by
// Twitter / Slack / LinkedIn / Facebook, so the social card points at a PNG.
const ogImage = new URL("/og-image.png", Astro.site).href;
const ogImageAlt = "kazi - the missing outer loop for coding agents";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/logo/kazi-badge.svg" />
    <!-- Honor the visitor's OS theme. color-scheme lets the UA pick light/dark
         form controls + scrollbars; theme-color is set per scheme so the mobile
         browser chrome matches the page in both. -->
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#0b1220" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f8fafc" media="(prefers-color-scheme: light)" />

    <!-- OpenGraph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="kazi" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
  </head>
  <body class="page-shell min-h-screen antialiased selection:bg-violet-500/30">
    <slot />
  </body>
</html>
